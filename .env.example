# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/builderreview
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_secure_random_string_min_64_chars
JWT_EXPIRY=15m
JWT_REFRESH_SECRET=change_me_to_another_secure_random_string
JWT_REFRESH_EXPIRY=7d

# ─── App ──────────────────────────────────────────────────────────────────────
API_PORT=4000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_me_nextauth_secret

# ─── S3 Storage ───────────────────────────────────────────────────────────────
S3_ENDPOINT=https://your-s3-endpoint
S3_BUCKET=builderreview
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_REGION=auto

# ─── WhatsApp (Meta Cloud API) ────────────────────────────────────────────────
WHATSAPP_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_ID=your_phone_number_id

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@builderreview.in

# ─── Razorpay Payouts ─────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ─── OTP ──────────────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
